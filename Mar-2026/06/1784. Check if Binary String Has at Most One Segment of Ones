/**
 * @param {string} s
 * @return {boolean}
 */
var checkOnesSegment = function(s) {
      let count=0,flag=0;
        for (let i = 0; i < s.length; i++) {
            if(s[i]=="1"&&flag==0){
                count++;
            }
            else{
                if(flag==1&&s[i]=="1") return false;
                flag=1;
            }
            
        }
        return true;
};
