/**
 * @param {number[]} nums
 * @return {number}
 */
var smallestBalancedIndex = function(nums) {


    let sum=[0],product=[];
    for(let i=1;i<nums.length;i++){
        sum[i]=sum[i-1]+nums[i-1];
    }
    product[nums.length-1]=1;
    for(let i=nums.length-2;i>=0;i--){
        product[i]=product[i+1]*nums[i+1];
    }

    for(let i=0;i<nums.length;i++){
        if(sum[i]==product[i]){
            return i
        }
    }
    return -1;
    
};
