 */
var minOperations = function (s) {
    let q=s.split('').sort().join('')
    console.log(q,s);
    let n=s.length-1;
   
    if(q==s) return 0
     if(n==1) return -1
    if(q[0]==s[0]&&q[n]==s[n]) return 1;
    if((q[0]==s[0]&&q[n]!==s[n])||(q[0]!==s[0]&&q[n]==s[n])) return 1;
    if(q[0]==q[1]||q[n]==q[n-1]) return 2
    if((q[0]!==s[0]&&q[n]!==s[n])&&(q[0]==s[n]&&s[0]==q[n])) return 3;
    return 2
    
};
