/**
 * @param {number} n
 * @return {number}
 */
var binaryGap = function(n) {
    
    n=n.toString(2).split('1')
    if(n.length<=2) return 0;
    let ans=0;
    
    for(let i=0;i<n.length;i++){
        if(i==n.length-1){
            if(Number(n[i])==0){
                continue;
            }
        }
        ans=Math.max(ans,n[i].length+1);
    }
    return ans;
};
