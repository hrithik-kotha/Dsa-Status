/**
 * @param {string} s
 * @param {number} k
 * @return {boolean}
 */
var hasAllCodes = function (s, k) {

    if (s.length < k) return false;

    let set = new Set();

    for (let i = 0; i < s.length; i++) {
        if (i + k <= s.length)
            set.add(s.substr(i, k));
    }
    // console.log(set)
 

    return set.size==1<<k;


};
